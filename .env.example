# Workstation .env — copy to `.env` (gitignored) and fill in real values.
# `launch_campaign.sh`, `bake_image.sh`, and `devenv-up.sh` expect to find
# these by `set -a; source .env; set +a` before running. See
# `.claude/skills/cloud-worker-ops.md` § "Initial workstation setup".

# Tailscale ephemeral + pre-approved auth key, tagged tag:starsector-worker.
# Generated at https://login.tailscale.com/admin/settings/keys.
# Resolved into smoke/prep YAMLs via `${TAILSCALE_AUTHKEY}` substitution.
TAILSCALE_AUTHKEY=tskey-auth-REPLACE_ME

# Boto3 profile name. Points at ~/.aws/credentials [starsector] which holds
# the dedicated IAM user (starsector-optimizer) with EC2FullAccess.
# Setup recipe in cloud-worker-ops.md.
AWS_PROFILE=starsector

# Path to a JDK 17 (matches Starsector's bundled JRE). Used by gradle for
# combat-harness builds. macOS Homebrew default below; Linux typically
# /usr/lib/jvm/java-17-openjdk.
STARSECTOR_JDK_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home

# Game license key, from the Starsector "Activation Key" email. Only used
# during operator-side setup (transcribing into scripts/cloud/packer/prefs.xml);
# not consumed at runtime by the campaign or workers.
STARSECTOR_SERIAL_KEY=XXXXX-XXXXX-XXXXX-XXXXX
