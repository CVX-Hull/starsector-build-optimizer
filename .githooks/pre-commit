#!/usr/bin/env bash
# Repository validation guard. Blocks commits that modify the combat-harness
# Java source or the Starsector game data without a corresponding manifest
# refresh, and keeps Codex AGENTS.md entrypoints symlinked to their CLAUDE.md
# sources.
#
# Opt-in per clone: `git config core.hooksPath .githooks`.
# Override: include `MANIFEST_REVIEWED: <reason>` on its own line in the
# commit message for changes that genuinely don't affect rules (comments,
# whitespace, test-only code).
#
# Rationale: spec 29 §Invariant — the manifest is the only authoritative
# source of game rules. Java mod edits OR data file edits can shift the
# content Python would read; shipping a stale manifest reintroduces the
# 14-bug drift treadmill that the Phase-7-prep refactor eliminated.

set -euo pipefail

staged_files() {
    git diff --cached --name-only --diff-filter=ACMR
}

validate_agents_symlinks() {
    local failed=0
    local claude_path dir agents_path target

    while IFS= read -r claude_path; do
        dir=$(dirname "$claude_path")
        if [ "$dir" = "." ]; then
            agents_path="AGENTS.md"
        else
            agents_path="$dir/AGENTS.md"
        fi

        if [ ! -L "$agents_path" ]; then
            printf 'pre-commit: %s must be a symlink to CLAUDE.md\n' "$agents_path" >&2
            failed=1
            continue
        fi

        target=$(readlink "$agents_path")
        if [ "$target" != "CLAUDE.md" ]; then
            printf 'pre-commit: %s points to %s, expected CLAUDE.md\n' "$agents_path" "$target" >&2
            failed=1
        fi
    done < <(find . -path ./.git -prune -o -name CLAUDE.md -print | sed 's#^\./##' | sort)

    if [ "$failed" -ne 0 ]; then
        cat >&2 <<'EOF'

Fix Codex compatibility by adding an AGENTS.md symlink next to each CLAUDE.md:

  ln -s CLAUDE.md AGENTS.md
EOF
        exit 1
    fi
}

needs_manifest_regen() {
    # Commit G R6: also gate on the Python schema loader. A Python-only
    # schema edit without paired manifest regen desyncs the schema-version
    # contract (old manifest → new loader raises ValueError at preflight).
    staged_files | grep -qE '^(combat-harness/src/main/|game/starsector/data/|src/starsector_optimizer/game_manifest\.py$)'
}

manifest_was_regen() {
    staged_files | grep -qx 'game/starsector/manifest.json'
}

override_in_message() {
    # Commit message may be in $1 (called by `git commit`) or
    # reachable via `git log -1`. Guard both paths.
    if [ $# -ge 1 ] && [ -f "$1" ]; then
        grep -q '^MANIFEST_REVIEWED:' "$1"
    else
        git log -1 --pretty=%B 2>/dev/null | grep -q '^MANIFEST_REVIEWED:'
    fi
}

validate_agents_symlinks

if needs_manifest_regen && ! manifest_was_regen; then
    if ! override_in_message "${1:-}"; then
        cat >&2 <<EOF
pre-commit: Java mod or game data changed without manifest regen.

Touched files:
$(staged_files | grep -E '^(combat-harness/src/main/|game/starsector/data/)' | sed 's/^/  /')

Manifest untouched: game/starsector/manifest.json

Fix one of:
  - Run \`uv run python scripts/update_manifest.py\` and \`git add\` the regenerated manifest.
  - Add \`MANIFEST_REVIEWED: <short reason>\` on its own line in the commit message
    if the change genuinely doesn't shift game rules (docs/comments/test-only code).

See docs/specs/29-game-manifest.md for the manifest-as-oracle invariant.
EOF
        exit 1
    fi
fi

exit 0
