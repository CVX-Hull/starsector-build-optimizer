# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
*.egg

# IDE
.idea/

# Game data (large binaries) — ignore everything under game/ except
# the authoritative manifest. Negation requires un-excluding parent
# directories first (gitignore "parent dir excluded" limitation).
game/*
!game/starsector/
game/starsector/*
!game/starsector/manifest.json

# OS
.DS_Store
Thumbs.db

# Gradle
combat-harness/.gradle/
combat-harness/build/
combat-harness/mod/jars/*.jar
combat-harness/mod/workdir/matchup.json
combat-harness/mod/workdir/result.json
combat-harness/mod/workdir/heartbeat.txt

# Active run artifacts (future runs write here, committed data lives in experiments/).
# Rooted because combat-harness/src/main/java/data/ is the Java `data` package
# (MissionDefinition + ManifestDumper live there), which must stay tracked.
# Use /data/* + targeted negations so the report-companion outputs (charts +
# headline_numbers.json) ride along with their reports under git, while raw
# logs / study DBs / per-trial ledgers stay out.
/data/*
!/data/wave1-comprehensive/
!/data/wave1-trajectory/
!/data/phase7-tail-walltime/
!/data/phase7-prequential-replay/
*.db

# Experiment databases (too large for git, back up separately)
experiments/**/*.db

# Orchestrator logs are ~70 MB of werkzeug/progress chatter per run —
# all load-bearing signals are either in events.log (extracted by
# scripts/cloud/extract_events.sh) or redundant with evaluation_log.jsonl
# and ledger.jsonl. Never commit.
experiments/**/orchestrator.log

# Notebook outputs (re-generated on execution)
notebooks/.ipynb_checkpoints/

# Local literature corpora can contain large PDFs and extracted text. Track the
# seed lists and synthesis docs; regenerate corpora with the literature skill.
/_research/**/corpus/

# Claude local state stays ignored, but repo workflow skills are tracked.
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/plans/
!.claude/plans/**

# Cloud secrets (Starsector serial key, Tailscale authkey, bearer tokens)
scripts/cloud/packer/prefs.xml
scripts/cloud/secrets/

# Local secrets — never commit
.env
.env.*
!.env.example
